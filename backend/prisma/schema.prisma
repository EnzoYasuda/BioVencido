generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id              Int               @id @default(autoincrement())
  nome            String            @db.VarChar(255)
  email           String            @unique @db.VarChar(255)
  senha           String            @db.VarChar(255)
  dataCadastro    DateTime          @default(now())

  alergias        Json?
  dietas          Json?
  notificacoes    Json?

  itens           ItensPereciveis[]
  enderecos       Endereco[]
  doacoes         Doacao[]
}

model ItensPereciveis {
  id           Int       @id @default(autoincrement())
  nome         String    @db.VarChar(255)
  categoria    String?   @db.VarChar(50)
  dataCompra   DateTime  @db.Date
  dataUso      DateTime? @db.Date
  dataValidade DateTime  @db.Date
  descricao    String?   @db.Text
  observacoes  String?   @db.Text
  quantidade   Int
  aberto       Boolean   @default(false)
  terminado    Boolean   @default(false)
  usuarioId    Int

  usuario      Usuario    @relation(fields: [usuarioId], references: [id])
  receitas     Receitas[]
  doacoes      Doacao[]
}

model Receitas {
  id               Int              @id @default(autoincrement())
  nome             String           @db.VarChar(255)
  categoria        String           @db.VarChar(255)
  descricao        String?          @db.Text
  modoPreparo      String           @db.Text
  nivelDificuldade String           @db.VarChar(20)
  tempoPreparoMin  Int?
  alergenos        Json?
  categoriaReceita String?          @db.VarChar(100)
  dieta            String?          @db.VarChar(50)
  itemId           Int?

  item             ItensPereciveis? @relation(fields: [itemId], references: [id])
}

model Endereco {
  id         Int     @id @default(autoincrement())
  rua        String  @db.VarChar(255)   // NOT NULL — conforme migration original
  numero     String  @db.VarChar(20)    // NOT NULL
  cidade     String  @db.VarChar(255)   // NOT NULL
  estado     String  @db.VarChar(255)   // NOT NULL
  cep        String  @db.VarChar(20)    // NOT NULL
  bairro     String? @db.VarChar(255)  // adicionado por migration_add_coords.sql
  // bairro NÃO existe no banco real (não estava na migration original)
  usuarioId  Int?

  usuario       Usuario?       @relation(fields: [usuarioId], references: [id])
  locaisDespejo LocalDespejo[]
  locaisDoacao  LocalDoacao[]
}

model LocalDespejo {
  id          Int     @id @default(autoincrement())
  nome        String  @db.VarChar(255)
  tipoProduto String? @db.VarChar(100)
  instrucoes  String? @db.Text
  restricoes  String? @db.Text
  enderecoId  Int?
  lat         Float?  // ← adicionado por migration_add_coords.sql
  lng         Float?  // ← adicionado por migration_add_coords.sql

  endereco    Endereco? @relation(fields: [enderecoId], references: [id])
}

model LocalDoacao {
  id                   Int     @id @default(autoincrement())
  nome                 String  @db.VarChar(255)
  tipoProduto          String? @db.VarChar(100)
  telefone             String? @db.VarChar(20)
  email                String? @db.VarChar(255)
  site                 String? @db.VarChar(255)
  horarioFuncionamento String? @db.VarChar(100)
  enderecoId           Int?
  lat                  Float?  // ← adicionado por migration_add_coords.sql
  lng                  Float?  // ← adicionado por migration_add_coords.sql

  endereco  Endereco?  @relation(fields: [enderecoId], references: [id])
  doacoes   Doacao[]
}

model Doacao {
  id            Int      @id @default(autoincrement())
  quantidade    Int
  dataDoacao    DateTime @default(now())
  usuarioId     Int?
  localDoacaoId Int?
  itemId        Int?

  usuario      Usuario?         @relation(fields: [usuarioId], references: [id])
  localDoacao  LocalDoacao?     @relation(fields: [localDoacaoId], references: [id])
  item         ItensPereciveis? @relation(fields: [itemId], references: [id])
}
